# OpenConnect Gateway v10 - Credenciais de Instalação
# ================================================
# PREENCHA este arquivo com suas credenciais reais
# NUNCA commite este arquivo no Git!
# ================================================

# R2 Cloudflare (para upload de clips)
R2_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=SEU_BUCKET
R2_ACCESS_KEY=SUA_ACCESS_KEY
R2_SECRET_KEY=SUA_SECRET_KEY

# Cloudflare Tunnels (para acesso externo a equipamentos FaceID)
CF_ACCOUNT_ID=SEU_ACCOUNT_ID
CF_API_TOKEN=SEU_API_TOKEN
CF_ZONE_ID=SEU_ZONE_ID

# Supabase (para sincronização de config)
CONFIG_TOKEN=SEU_CONFIG_TOKEN
CONFIG_URL=https://SEU_PROJETO.supabase.co/functions/v1/openconnect-v4-config?gateway_id=SEU_GATEWAY_ID
